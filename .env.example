# Database
DATABASE_URL=postgresql+asyncpg://fintech:fintech_pass@localhost:5432/fintech
DATABASE_URL_SYNC=postgresql://fintech:fintech_pass@localhost:5432/fintech

# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# PostgreSQL (Docker Compose)
POSTGRES_DB=fintech
POSTGRES_USER=fintech
POSTGRES_PASSWORD=fintech_pass

# App
APP_ENV=development
MAX_UPLOAD_SIZE_MB=20
LLM_RATE_LIMIT_PER_MINUTE=30
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
